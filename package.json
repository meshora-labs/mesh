{
	"name": "mesh",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Local-first desktop workbench for orchestrating projects, agents, runs, and model context.",
	"scripts": {
		"dev": "vite --host 0.0.0.0 --port 1420",
		"build": "tsc --noEmit && vite build",
		"test": "vitest run --config vitest.config.ts",
		"typecheck": "tsc --noEmit",
		"format": "biome format . --write",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"biome:check": "biome check .",
		"biome:write": "biome check . --write",
		"verify": "pnpm run biome:check && pnpm run typecheck",
		"preview": "vite preview",
		"prepare": "node scripts/install-git-hooks.mjs",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build --debug --no-bundle"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.0",
		"lucide-react": "^1.14.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	},
	"devDependencies": {
		"@tauri-apps/cli": "^2.11.0",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"biome": "^0.3.3",
		"jsdom": "^29.1.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	}
}
