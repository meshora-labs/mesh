{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mesh",
  "version": "0.1.0",
  "identifier": "com.shayn.mesh",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mesh",
        "center": true,
        "width": 1280,
        "height": 760,
        "minWidth": 1120,
        "minHeight": 760,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 20,
          "y": 23
        },
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
