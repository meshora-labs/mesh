{
  "extends": "@tsconfig/node24/tsconfig.json",
  "_version": "24.15.0",
  "compilerOptions": {
    "composite": true,
    "target": "ES2025",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vitest.config.ts"]
}
